"\n"
"        Règles di convalida personnalisées.\n"
"        Formato: [\n"
"            {\"tipo\": \"required_if\", \"field\": \"iva_number\", \"condition\": \"forma_giuridico == 'LA SUA'\"},\n"
"            {\"tipo\": \"regex\", \"field\": \"ide_number\", \"pattern\": \"^CHE-\\d{3}\\.\\d{3}\\.\\d{3}$\"}\n"
"        ]\n"
"        "

