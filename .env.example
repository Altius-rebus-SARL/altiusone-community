# =============================================================================
# AltiusOne Community Edition — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# All passwords below are EXAMPLES — change them before deploying!
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# PostgreSQL (used by docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_DB=altiusone
POSTGRES_USER=altiusone
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Set to True for development (tasks run synchronously, no worker needed)
# CELERY_TASK_ALWAYS_EAGER=False

# -----------------------------------------------------------------------------
# MinIO / S3 Storage
# -----------------------------------------------------------------------------
USE_S3=true
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio
AWS_STORAGE_BUCKET_NAME=altiusone-media
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
DJANGO_PORT=8011
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Email (optional — defaults to console backend in DEBUG mode)
# -----------------------------------------------------------------------------
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=your-32-url-safe-base64-encoded-key-here

# -----------------------------------------------------------------------------
# AI Service (optional — AltiusOne works fully without AI)
# -----------------------------------------------------------------------------
# Point to any OpenAI-compatible API (Ollama, vLLM, LiteLLM, etc.)
# AI_API_URL=http://localhost:11434
# AI_API_KEY=
#
# The MCP server (mcp/) is always available for connecting external LLMs.
# See CONTRIBUTING.md for details.

# Search tuning (defaults are fine for most setups)
# SEARCH_FULLTEXT_WEIGHT=0.4
# SEARCH_SEMANTIC_WEIGHT=0.6
# SEARCH_SEMANTIC_THRESHOLD=0.5
