# AltiusOne Instance Configuration
# Copy this file to .env and configure your values

# =============================================================================
# DOMAIN
# =============================================================================
DOMAIN=your-domain.altiusone.ch

# =============================================================================
# DATABASE (PostgreSQL with PostGIS)
# =============================================================================
POSTGRES_DB=altiusone
POSTGRES_USER=altiusone
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=altiusone_postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://altiusone:your-secure-password-here@altiusone_postgres:5432/altiusone

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# =============================================================================
# CELERY (Task Queue)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# DJANGO
# =============================================================================
# Generate a secure key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.altiusone.ch,localhost,127.0.0.1
DJANGO_PORT=8000

# =============================================================================
# CORS (for mobile app)
# =============================================================================
CORS_ALLOW_ALL_ORIGINS=False

# =============================================================================
# NGINX
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# EMAIL
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@domain.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=noreply@your-domain.ch

# =============================================================================
# SECURITY
# =============================================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# =============================================================================
# FILE UPLOAD
# =============================================================================
MAX_UPLOAD_SIZE=10485760

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
